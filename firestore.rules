rules_version = '2';

// Rules for مشروع أسماء الله الحسنى
// - Students: read/write their own profile + progress
// - Admin (role='admin' in their users/{uid} doc): read all, edit names catalog
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: caller is admin
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users can read/write their own profile; admins can read everyone.
    match /users/{uid} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Each user's memorization progress: they own it; admins can read.
    match /users/{uid}/progress/{nameId} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Reserved for future: per-user daily sessions
    match /users/{uid}/sessions/{sessionId} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Reserved for future: private reflections per user
    match /users/{uid}/reflections/{nameId} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // The 99 names catalog. Everyone signed-in reads. Only admin edits.
    match /names/{nameId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // Courses catalog. Everyone signed-in reads. Only admin edits.
    match /courses/{courseId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();

      match /lessons/{lessonId} {
        allow read:  if request.auth != null;
        allow write: if isAdmin();
      }
    }

    // Per-user lesson progress. User owns theirs; admins can read.
    match /users/{uid}/lessonProgress/{lessonId} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Shared reflections queue (student opts in to share with teacher)
    match /reflections/{id} {
      allow read:   if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }
  }
}
