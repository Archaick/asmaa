VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Comma-separated list of emails that get 'admin' role on first sign-in.
# Only used if the user's Firestore doc doesn't already have a role set.
# Note: VITE_* vars are inlined into the client bundle — not a secret.
# For true server-side gating, use Firebase custom claims via a Cloud Function.
VITE_ADMIN_EMAILS=
